# Keeps secrets, runtime data, generated artifacts, and local tooling files out of Git.

# Local-only configuration and secrets
keys.py
.optedge_status.json
config_runtime.py
.env
.env.*
!.env.example

# Runtime data, caches, and outputs
data/_cache/
data/cockpit_jobs/
data/robinhood_account_equity_ledgers/
data/weights/*.json
data/*.parquet
data/*.json
data/*.html
data/*.txt
data/*.jsonl
data/*.png
data/*.csv
data/*.md
# Keep the data-directory privacy guide visible in every clone.
!data/README.md
data/lookup_reports/
logs/*.parquet
logs/*.json
telemetry/*.parquet
telemetry/*.jsonl
archive/

# Python environments, caches, coverage, and builds
__pycache__/
*.pyc
venv/
.venv/
env/
.codex_git/
*.egg-info/
.pytest_cache/
.pytest_tmp/
.pytest_tmp_*/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
.tox/
.nox/
build/
dist/

# Local databases, logs, and editor backups
*.log
*.db
*.sqlite
*.sqlite3
*.tmp
*.bak
*.orig
*.swp
.idea/
.vscode/

# OS
.DS_Store
Thumbs.db
